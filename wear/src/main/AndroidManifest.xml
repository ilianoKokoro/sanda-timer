        <service
            android:name=".modules.widget.TimerWidgetService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/sanda_timers"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">

            <intent-filter>
                <action android:name="androidx.glance.wear.action.BIND_WIDGET_PROVIDER" />
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>

            <meta-data
                android:name="androidx.glance.wear.widget.provider"
                android:resource="@xml/timer_widget_info" />

            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/timer_widget_preview" />
        </service>

        <receiver
            android:name=".core.receivers.TimerExpiredReceiver"
            android:exported="false" />

        <receiver
            android:name=".core.receivers.BootReceiver"
            android:directBootAware="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <uses-library
            android:name="com.google.android.wearable"
            android:required="true" />
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />
        
        <activity
            android:name=".modules.application.MainActivity"
            android:exported="true"
            android:theme="@style/MainActivityTheme.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>